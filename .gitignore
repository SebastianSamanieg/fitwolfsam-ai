ENV/

# ─────────────────────────────────────────────────────────────────────────────
# ─── 3. CACHÉ DE BYTECODE ────────────────────────────────────────────────────
# Archivos compilados por Python en tiempo de ejecución. Auto-generados.
# ─────────────────────────────────────────────────────────────────────────────

__pycache__/
*.py[codz]
*.pyc
*.pyo
*.pyd
*$py.class

