build/
dist/
wheels/
eggs/
.eggs/
develop-eggs/
downloads/
lib/
lib64/
parts/
sdist/
var/
share/python-wheels/
*.egg
*.egg-info/
.installed.cfg
MANIFEST
.Python

# ─────────────────────────────────────────────────────────────────────────────
# ─── 5. BINARIOS Y EXTENSIONES COMPILADAS ────────────────────────────────────
